profiles {
  isca {
    params.base               = '/lustre/projects/Research_Project-MRC147594'
    params.software           = "${params.base}/software"
    params.picardJar          = "${params.software}/picard3/picard.jar"
    params.gatkJar            = "${params.software}/gatk4/gatk-4.6.1.0/gatk-package-4.6.1.0-local.jar"
    params.referenceFasta     = "${params.base}/resources/grch38-v2-pipeline/Homo_sapiens_assembly38.fasta"
    params.exomeDepthReference= "${params.base}/resources/exome_depth_reference3/"
    params.tmpDir             = "${params.base}/genome_sequencing/NF_temp/"
    params.goldStandardIndels = "${params.base}/resources/grch38-v2-pipeline/Mills_and_1000G_gold_standard.indels.hg38.vcf"
    params.dbSnp              = "${params.base}/resources/grch38-v2-pipeline/Homo_sapiens_assembly38.dbsnp138.vcf"
    params.resourcesDir       = "${params.base}/resources/resources3/"
    params.gnomadCommon       = "${params.base}/resources/grch37/gnomad_common.object"
    params.gnomadAll          = "${params.base}/resources/grch37/gnomad_all.object"
    params.javaDir            = "${params.software}/in-house/software/java"
    params.auxSoftware        = "${params.software}/in-house/software/exome_pipeline"
    params.alamut             = "${params.software}/alamut/alamut-batch-standalone-1.11/alamut-batch"
    params.bwa                = "${params.software}/bwa-mem2/bwa-mem2-2.2.1_x64-linux/bwa-mem2"
    params.rScript            = "${params.software}/R/R-3.0.2/bin/Rscript"
    params.kevlarMask         = "${params.base}/resources/kevlar/b37_mask.ct"
    // SLURM specific settings
    params.pbsQueueing        = true
    process.executor = 'slurm'
    process.queue = 'mrcq'
  }

  ennis {
    params.base               = '/ennis/projects/Research_Project-MRC147594'
    params.software           = "${params.base}/software"
    params.tmpDir             = '/scratch'
    params.picardJar          = "${params.software}/picard/picard-2-7-1.jar"
    params.gatkJar            = "${params.software}/gatk/GenomeAnalysisTK-nightly-2016-12-05-ga159770/GenomeAnalysisTK.jar"
    params.referenceFasta     = "${params.base}/resources/grch38-v2-pipeline/human_g1k_v37.fasta"
    params.exomeDepthReference= "${params.base}/resources/exome_depth_reference3/"
    params.goldStandardIndels = "${params.base}/resources/grch38-v2-pipeline/Mills_and_1000G_gold_standard.indels.b37.vcf"
    params.dbSnp              = "${params.base}/resources/grch37/dbsnp_141.b37.vcf"
    params.resourcesDir       = "${params.base}/resources/resources3/"
    params.gnomadCommon       = "${params.base}/resources/grch37/gnomad_common.object"
    params.gnomadAll          = "${params.base}/resources/grch37/gnomad_all.object"
    params.javaDir            = "${params.software}/in-house/software/java"
    params.auxSoftware        = "${params.software}/in-house/software/exome_pipeline"
    params.alamut             = "${params.software}/alamut/alamut-batch-standalone-1.11/alamut-batch"
    params.bwa                = "${params.software}/bwa/bwa-0.7.15/bwa"
    params.rScript            = "${params.software}/R/R-3.0.2/bin/Rscript"
    params.kevlarMask         = "${params.base}/resources/kevlar/b37_mask.ct"
    params.pbsQueueing        = false
  }
}
plugins {
  id 'nf-boost'
}

boost {
  cleanup = true
}